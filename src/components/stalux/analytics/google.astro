---
import { getCollection } from "astro:content";
const configCollection = await getCollection("config");
const config = configCollection[0];
const gaID = config.data.head?.googleAnalyticsId;
---

<Fragment set:html={`<script async src="https://www.googletagmanager.com/gtag/js?id=${gaID}" type="text/javascript"></script>
<script type="text/javascript">
    window.dataLayer = window.dataLayer || [];
    function gtag() {
        dataLayer.push(arguments);
    }
    gtag("js", new Date());
    gtag("config", "${gaID}");
</script>`} />
