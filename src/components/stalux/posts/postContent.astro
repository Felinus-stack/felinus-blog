---
import style from "@styles/components/posts/postContent.module.css";
import "@styles/components/markdown.css";
import "katex/dist/katex.min.css";
import "photoswipe/dist/photoswipe.css";

interface Props {
    title: string;
    date?: string;
    updated?: string;
    readingTime?: string;
}

const { title, date, updated, readingTime } = Astro.props;
---

<article class={style.articleContent}>
    <!-- Article Header -->
    <header class={style.articleHeader}>
        <h1 class={style.title}>{title}</h1>
        <div class={style.metadata}>
            {
                date && (
                    <time class={style.metaItem} datetime={date}>
                        发布时间：
                        {new Date(date).toLocaleDateString("zh-CN", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })}
                    </time>
                )
            }

            {
                updated && (
                    <span class={style.metaItem}>
                        更新时间：
                        {new Date(updated).toLocaleDateString("zh-CN", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })}
                    </span>
                )
            }
        </div>
        {
            (readingTime || true) && (
                <div class={style.pageStats}>
                    {readingTime && (
                        <span class={style.readingTime}>
                            🕒 阅读时间：{readingTime}
                        </span>
                    )}
                    <span id="vercount_container_page_pv">
                        👀 阅读量：
                        <span id="vercount_value_page_pv">Loading...</span>
                    </span>
                </div>
            )
        }
    </header>

    <!-- Article Body -->
    <div class={style.body} data-pagefind-body>
        <slot />
    </div>
</article>

<script>
    import PhotoSwipeLightbox from "photoswipe/lightbox";
    import PhotoSwipe from "photoswipe";
    // 动态获取图片尺寸并更新 PhotoSwipe 数据属性
    function enrichPhotoSwipeData() {
        const container = document.querySelector("[data-pagefind-body]");
        if (!container) return;

        const links = container.querySelectorAll("a[data-pswp]");
        links.forEach((link) => {
            const img = link.querySelector("img");
            if (!img) return;

            // 创建临时图片对象以获取真实尺寸
            const tempImg = new Image();
            tempImg.onload = () => {
                link.setAttribute(
                    "data-pswp-width",
                    String(tempImg.naturalWidth),
                );
                link.setAttribute(
                    "data-pswp-height",
                    String(tempImg.naturalHeight),
                );
            };
            tempImg.src = img.src;
        });
    }

    // 初始化灯箱
    function initLightbox() {
        enrichPhotoSwipeData();
        const lightbox = new PhotoSwipeLightbox({
            gallery: "[data-pagefind-body]",
            children: "a[data-pswp]",
            pswpModule: PhotoSwipe,
            initialZoomLevel: "fill",
        });
        lightbox.init();
    }

    // 在 DOM 就绪时初始化
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initLightbox);
    } else {
        // 延迟以确保图片已加载
        setTimeout(initLightbox, 100);
    }
</script>
