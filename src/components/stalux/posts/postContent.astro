---
import { fade } from "astro:transitions";
import style from "@styles/components/posts/postContent.module.css";
import "@styles/components/markdown.css";
import { getCollection } from "astro:content";
import { toMachineDateTime } from "@utils/semantic-time";

interface Props {
    title: string;
    date?: string;
    updated?: string;
    readingTime?: string;
    wordCount?: number;
    hasImage?: boolean;
}

const props = Astro.props as Props;
const stalux = (await getCollection("config"))[0]?.data;
const timezone = stalux?.timezone;
---

<article
    class={style.articleContent}
    transition:name="post-content"
    transition:animate={fade({ duration: "1.2s" })}>
    <!-- Article Header -->
    <header class={style.articleHeader}>
        <h1 class={style.title}>{props.title}</h1>
        <div class={style.metadata}>
            {
                props.date && (
                    <time class={style.metaItem} datetime={timezone ? toMachineDateTime(props.date, timezone) : props.date}>
                        发布时间：
                        {props.date}
                    </time>
                )
            }

            {
                props.updated && (
                    <time class={style.metaItem} datetime={timezone ? toMachineDateTime(props.updated, timezone) : props.updated}>
                        更新时间：
                        {props.updated}
                    </time>
                )
            }
        </div>
        {
            (props.readingTime || true) && (
                <div class={style.pageStats}>
                    {props.readingTime && (
                        <span class={style.readingTime}>
                            🕒 阅读时间：{props.readingTime}
                        </span>
                    )}
                    {props.wordCount && props.wordCount > 0 && (
                        <span class={style.wordCount}>
                            📝 字数：{props.wordCount}
                        </span>
                    )}
                    <span id="vercount_container_page_pv">
                        👀 阅读量：
                        <span id="vercount_value_page_pv">Loading...</span>
                    </span>
                </div>
            )
        }
    </header>

    <!-- Article Body -->
    <div class={style.body} data-pagefind-body>
        <slot />
    </div>
</article>

{
    props.hasImage && (
        <script>
            import PhotoSwipeLightbox from "photoswipe/lightbox";
            import PhotoSwipe from "photoswipe";

            function enrichPhotoSwipeData() {
                const container = document.querySelector("[data-pagefind-body]");
                if (!container) return;

                const links = container.querySelectorAll("a[data-pswp]");
                links.forEach((link) => {
                    const img = link.querySelector("img");
                    if (!img) return;

                    const tempImg = new Image();
                    tempImg.onload = () => {
                        link.setAttribute(
                            "data-pswp-width",
                            String(tempImg.naturalWidth),
                        );
                        link.setAttribute(
                            "data-pswp-height",
                            String(tempImg.naturalHeight),
                        );
                    };
                    tempImg.src = img.src;
                });
            }

            function initLightbox() {
                enrichPhotoSwipeData();
                const lightbox = new PhotoSwipeLightbox({
                    gallery: "[data-pagefind-body]",
                    children: "a[data-pswp]",
                    pswpModule: PhotoSwipe,
                    initialZoomLevel: "fill",
                });
                lightbox.init();
            }

            document.addEventListener("astro:page-load", initLightbox);
        </script>
    )
}
