---
import "@waline/client/style";

export interface Props {
    path?: string;
    title?: string;
    serverURL?: string;
    lang?: string;
    locale?: any;
    emoji?: any;
    requiredMeta?: string[];
    reaction?: boolean;
    meta?: string[];
    wordLimit?: number;
    pageSize?: number;
    login?: string;
    recaptchaV3Key?: string;
    turnstileKey?: string;
    dark?: string | boolean;
    noCopyright?: boolean;
    commentSorting?: string;
    imageUploader?: any;
    highlighter?: any;
    texRenderer?: any;
    search?: any;
}

const {
    path = typeof window !== "undefined" ? window.location.pathname : "",
    title = "",
    serverURL = "",
    lang = "zh-CN",
    locale = undefined,
    emoji = false,
    requiredMeta = [],
    reaction = true,
    meta = ["nick", "mail", "link"],
    wordLimit = 200,
    pageSize = 10,
    login = "enable",
    recaptchaV3Key = "",
    turnstileKey = "",
    dark = true,
    noCopyright = false,
    commentSorting = "latest",
    imageUploader = undefined,
    highlighter = undefined,
    texRenderer = undefined,
    search = undefined,
} = Astro.props;

// 为客户端脚本准备配置对象
const walineConfig = {
    path,
    title,
    serverURL,
    lang,
    locale,
    emoji,
    requiredMeta,
    reaction,
    meta,
    wordLimit,
    pageSize,
    login,
    recaptchaV3Key,
    turnstileKey,
    dark,
    noCopyright,
    commentSorting,
    imageUploader,
    highlighter,
    texRenderer,
    search,
};
---

{
    serverURL && (
        <div
            id="waline-container"
            class="waline-comment-container"
            data-waline-config={
                // base64 可逆混淆（无 unescape，兼容 Node/浏览器）
                Buffer.from(
                    new TextEncoder().encode(JSON.stringify(walineConfig)),
                ).toString("base64")
            }
        >
            <h2 class="waline-comment-title">留言评论</h2>
            <div id="waline-comment" class="waline-comment" data-nosnippet />
            <div class="comments-seo-notice" style="display:none">
                评论区内容由用户生成，不代表网站观点
            </div>
        </div>
    )
}

<script>
    import { init } from "@waline/client";
    let walineInstance: ReturnType<typeof init> | null = null;

    // 安全销毁 Waline 实例
    const safeDestroy = () => {
        try {
            if (walineInstance?.destroy) {
                const commentEl = document.getElementById("waline-comment");
                if (commentEl && commentEl.parentNode) {
                    walineInstance.destroy();
                }
            }
        } catch (e) {
            console.warn("Waline destroy error:", e);
        }
        walineInstance = null;
    };

    // 初始化 Waline 评论系统
    const initWaline = async () => {
        const container = document.getElementById("waline-container");
        if (!container) {
            return;
        }

        let walineConfig;
        try {
            // base64 可逆混淆解码（无 unescape，兼容 Node/浏览器）
            const base64 = container.dataset.walineConfig || "";
            const bytes = Uint8Array.from(atob(base64), (c) => c.charCodeAt(0));
            const jsonStr = new TextDecoder().decode(bytes);
            walineConfig = JSON.parse(jsonStr);
        } catch (error) {
            console.error("Failed to decode Waline config:", error);
            return;
        }

        // 先销毁旧实例
        safeDestroy();

        if (!walineConfig.serverURL) {
            console.warn("Waline serverURL not configured");
            return;
        }

        const commentEl = document.getElementById("waline-comment");
        if (!commentEl) {
            return;
        }

        try {
            walineInstance = init({
                el: commentEl,
                serverURL: walineConfig.serverURL,
                path: walineConfig.path || window.location.pathname,
                lang: walineConfig.lang,
                locale: walineConfig.locale,
                emoji: walineConfig.emoji,
                requiredMeta: walineConfig.requiredMeta,
                reaction: walineConfig.reaction,
                meta: walineConfig.meta,
                wordLimit: walineConfig.wordLimit,
                pageSize: walineConfig.pageSize,
                login: walineConfig.login,
                recaptchaV3Key: walineConfig.recaptchaV3Key,
                turnstileKey: walineConfig.turnstileKey,
                dark: walineConfig.dark,
                noCopyright: walineConfig.noCopyright,
                commentSorting: walineConfig.commentSorting,
                imageUploader: walineConfig.imageUploader,
                highlighter: walineConfig.highlighter,
                texRenderer: walineConfig.texRenderer,
                search: walineConfig.search,
            });
        } catch (error) {
            console.error("Failed to initialize Waline:", error);
        }
    };

    // 首屏加载
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initWaline, {
            once: true,
        });
    } else {
        setTimeout(initWaline, 0);
    }

    // 视图过渡：页面导航前清理
    document.addEventListener("astro:before-swap", safeDestroy);

    // 视图过渡：页面导航后重新初始化
    document.addEventListener("astro:page-load", initWaline);
</script>

<style is:global>
    /* 评论区容器与博客风格一致 */
    .waline-comment-container {
        margin-top: 3rem;
        margin-bottom: 1rem;
        padding: 2rem;
        border-radius: 12px;
        animation: fadeInUp 0.8s ease-in-out forwards;
        opacity: 0;
        animation-delay: 0.3s;
    }

    /* 评论区标题样式与博客风格一致 */
    .waline-comment-title {
        margin: 0 0 1.5rem 0;
        font-size: 2rem;
        text-align: center;
        background: linear-gradient(
            90deg,
            var(--white-90p),
            rgba(var(--waline-accent-rgb), 0.9)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Waline根元素自定义 */
    .wl-panel {
        background-color: rgba(17, 17, 17, 0.3);
        border-radius: 12px;
        padding: 1rem;
        border: 1px solid var(--white-10p);
        margin-bottom: 1.5rem;
    }

    /* 修改输入框样式 */
    .wl-editor,
    .wl-input {
        background-color: rgba(17, 17, 17, 0.5) !important;
        color: var(--white-90p) !important;
        border: 1px solid rgba(100, 100, 100, 0.3) !important;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    /* 输入框焦点状态 */
    .wl-editor:focus,
    .wl-input:focus {
        border-color: rgba(var(--waline-accent-rgb), 0.5) !important;
        box-shadow: 0 0 5px rgba(var(--waline-accent-rgb), 0.3) !important;
        outline: none;
    }

    /* 按钮样式统一 */
    .wl-btn {
        background: rgba(var(--waline-accent-rgb), 0.6) !important;
        color: var(--white-full) !important;
        border: none !important;
        border-radius: 6px;
        transition: all 0.2s ease;
        font-weight: 500;
        padding: 8px 15px;
        cursor: pointer;
    }

    .wl-btn:hover {
        background: rgba(var(--waline-accent-rgb), 0.7) !important;
        transform: none;
        box-shadow: none !important;
    }

    .wl-btn.primary {
        background: rgba(var(--waline-accent-rgb), 0.6) !important;
    }

    .wl-btn.primary:hover {
        background: rgba(var(--waline-accent-rgb), 0.7) !important;
        transform: none;
        box-shadow: none !important;
    }

    /* 标签文字颜色 */
    .wl-header label {
        color: var(--white-85p);
        font-weight: 500;
    }

    /* 评论卡片样式 */
    .wl-card {
        background-color: rgba(17, 17, 17, 0.3) !important;
        border-radius: 12px;
        padding: 1.2rem;
        margin-top: 1.2rem;
        border: 1px solid rgba(70, 70, 70, 0.2) !important;
        transition: all 0.3s ease;
    }

    .wl-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        border-color: rgba(var(--waline-accent-rgb), 0.3) !important;
    }

    /* 修改用户名样式 */
    .wl-nick {
        color: rgba(var(--waline-accent-rgb), 0.95) !important;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .wl-nick:hover {
        color: rgba(var(--waline-accent-rgb), 1) !important;
    }

    /* 评论内容样式 */
    .wl-content {
        color: var(--white-90p);
        line-height: 1.7;
        margin: 0.8rem 0;
        word-break: break-word;
    }

    /* 回复按钮样式 */
    .wl-reply {
        opacity: 0.8;
        transition: all 0.2s ease;
    }

    .wl-reply:hover {
        opacity: 1;
        text-decoration: none;
    }

    /* 表情面板样式 */
    .wl-emoji-popup,
    .wl-gif-popup {
        background-color: rgba(25, 25, 25, 0.95) !important;
        border: 1px solid rgba(70, 70, 70, 0.3) !important;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        backdrop-filter: blur(11px);
    }

    /* 表情按钮样式 */
    .wl-emoji-popup button {
        border-radius: 6px;
        transition: all 0.2s ease;
    }

    .wl-emoji-popup button:hover {
        background-color: rgba(var(--waline-accent-rgb), 0.2);
        transform: scale(1.05);
    }

    /* 文章评价反应区域 */
    .wl-reaction {
        background-color: rgba(17, 17, 17, 0.3);
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(70, 70, 70, 0.2);
        text-align: center;
    }

    .wl-reaction-title {
        font-size: 1.1rem;
        margin-bottom: 1rem;
        color: var(--white-90p);
    }

    .wl-reaction-list {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
    }

    .wl-reaction-item {
        background-color: rgba(30, 30, 30, 0.5) !important;
        border-radius: 8px;
        margin: 5px;
        transition: all 0.3s ease;
        cursor: pointer;
        border: 1px solid rgba(70, 70, 70, 0.2) !important;
    }

    .wl-reaction-item:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 10px rgba(0, 0, 0, 0.2);
        background-color: rgba(40, 40, 40, 0.8) !important;
        border-color: rgba(var(--waline-accent-rgb), 0.3) !important;
    }

    .wl-reaction-img {
        padding: 6px;
    }

    .wl-reaction-img img {
        transition: transform 0.3s ease;
    }

    .wl-reaction-item:hover .wl-reaction-img img {
        transform: scale(1.15);
    }

    .wl-reaction-votes {
        font-size: 0.8rem;
        padding: 5px 0;
        background-color: rgba(var(--waline-accent-rgb), 0.7);
        color: #fff;
    }

    /* 评论计数和排序 */
    .wl-meta-head {
        margin-bottom: 1.2rem;
        border-bottom: 1px solid rgba(70, 70, 70, 0.3);
        padding-bottom: 0.8rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .wl-count {
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--white-90p);
    }

    .wl-sort {
        display: flex;
        gap: 1rem;
    }

    .wl-sort li {
        cursor: pointer;
        transition: all 0.2s ease;
        color: var(--white-70p);
    }

    .wl-sort li:hover {
        color: var(--white-90p);
    }

    .wl-sort li.active {
        color: rgba(var(--waline-accent-rgb), 1);
        font-weight: 500;
    }

    /* 页码导航 */
    .wl-page {
        margin-top: 1.2rem;
        text-align: center;
    }

    .wl-page button {
        background: rgba(30, 30, 30, 0.5) !important;
        color: var(--white-80p) !important;
        border: 1px solid rgba(70, 70, 70, 0.3) !important;
        border-radius: 6px;
        margin: 0 5px;
        padding: 5px 10px;
        transition: all 0.2s ease;
    }

    .wl-page button:hover:not(:disabled) {
        background: rgba(var(--waline-accent-rgb), 0.7) !important;
        color: #fff !important;
        transform: translateY(-2px);
    }

    .wl-page button.active {
        background: rgba(var(--waline-accent-rgb), 0.8) !important;
        color: #fff !important;
    }

    /* Waline底部版权信息 */
    .wl-power {
        opacity: 0.6;
        font-size: 0.85rem;
        margin-top: 2rem;
        text-align: center;
    }

    .wl-power a {
        color: rgba(var(--waline-accent-rgb), 0.9);
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .wl-power a:hover {
        color: rgba(var(--waline-accent-rgb), 1);
        text-decoration: underline;
    }

    /* 评论为空状态 */
    .wl-empty {
        text-align: center;
        padding: 2rem 0;
        color: var(--white-60p);
        font-size: 1.1rem;
    }

    /* 支持文字数量统计 */
    .wl-text-number {
        font-size: 0.9rem;
        color: var(--white-60p);
    }

    /* 添加动画效果 */
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* 降低选中文本高亮程度，移除外边框 */
    .waline-comment-container *::selection {
        background: rgba(var(--waline-accent-rgb), 0.25);
        color: inherit;
        border: none;
        outline: none;
    }

    .waline-comment-container *::-moz-selection {
        background: rgba(var(--waline-accent-rgb), 0.25);
        color: inherit;
        border: none;
        outline: none;
    }

    /* 响应式调整 */
    @media (max-width: 768px) {
        .waline-comment-container {
            padding: 0.8rem;
            margin-top: 2rem;
            margin-left: -1.5rem;
            margin-right: -1.5rem;
            border-radius: 0;
        }

        .waline-comment-title {
            font-size: 1.8rem;
        }

        .wl-panel {
            padding: 1rem;
            width: 100%;
            box-sizing: border-box;
        }

        .wl-header {
            flex-direction: column;
        }

        .wl-header-item {
            width: 100%;
            margin-bottom: 0.5rem;
        }

        .wl-editor,
        .wl-input {
            width: 100%;
            box-sizing: border-box;
        }

        /* 平板设备上的嵌套评论处理 */
        .wl-card {
            padding: 0.8rem;
            margin-left: 0;
            margin-top: 0.8rem;
        }

        .wl-children {
            margin-left: 0;
            padding-left: 0;
        }

        .wl-children .wl-card {
            margin-left: 0;
            border-left: 3px solid rgba(var(--waline-accent-rgb), 0.4);
            padding-left: 0.8rem;
        }
    }

    @media (max-width: 480px) {
        .waline-comment-container {
            padding: 0.6rem;
            margin-top: 1.5rem;
            margin-left: -1rem;
            margin-right: -1rem;
            border-radius: 0;
        }

        .waline-comment-title {
            font-size: 1.6rem;
        }

        .wl-panel {
            padding: 0.8rem;
            width: 100%;
            box-sizing: border-box;
        }

        .wl-reaction-list {
            gap: 5px;
        }

        .wl-card {
            padding: 0.75rem;
            margin-left: 0;
            margin-top: 0.8rem;
            width: 100%;
            box-sizing: border-box;
        }

        /* 小屏幕上的嵌套评论处理 */
        .wl-children {
            margin-left: 0;
            padding-left: 0;
            width: 100%;
            box-sizing: border-box;
        }

        .wl-children .wl-card {
            margin-left: 0;
            border-left: 3px solid rgba(1, 162, 190, 0.4);
            padding-left: 0.6rem;
            width: 100%;
        }

        .wl-children .wl-children .wl-card {
            border-left: 3px solid rgba(var(--waline-accent-rgb), 0.3);
            padding-left: 0.6rem;
        }

        .wl-meta-head {
            flex-direction: column;
            gap: 0.5rem;
            align-items: flex-start;
        }

        .wl-editor,
        .wl-input {
            width: 100%;
            box-sizing: border-box;
        }
    }
</style>
